BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=replace-with-long-random-string

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODEL_PATH=./data/svd_model.pkl
