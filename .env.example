# Copy to backend/.env for local runs, or set in docker-compose / Neon dashboard.
#
# Local (no Docker): SQLite — tables are created automatically on first API start.
# DATABASE_URL=sqlite:///./movie_rec.db
#
# Docker / local Postgres:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/movie_rec
# Neon example:
# DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=replace-with-long-random-string

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODEL_PATH=./data/svd_model.pkl

# Set true while debugging 500 errors — JSON responses include exception message.
DEBUG=false

# Frontend (optional): production build uses VITE_API_URL.
# Dev uses Vite proxy; Docker Compose sets VITE_PROXY_TARGET=http://api:8000 for the web service.
